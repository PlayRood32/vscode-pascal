{
  "comments": {
    "lineComment": "//",
    "blockComment": [ ["{", "}"], ["(*", "*)"] ]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "(*", "close": "*)", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["'", "'"],
    ["\"", "\""],
    ["(*", "*)"]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*(\\{|\$$   \\*|begin|repeat|record|class|object|interface|case|try|except|finally|asm)\\b",
      "end": "^\\s*(\\}|\\*\   $$|end|until)\\b"
    }
  },
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([_\\w][^\\`\\~\\!\\@\\#\\%\\^\\&\\*\$$   \   $$\\-\\=\\+\$$   \\{\   $$\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)",
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(begin|record|class|object|interface|case|repeat|try|except|finally|asm|procedure|function)\\b",
    "decreaseIndentPattern": "^\\s*(end|until|else)\\b"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*begin\\s*$",
      "action": { "indent": "indent" }
    },
    {
      "beforeText": "^\\s*end\\s*$",
      "action": { "indent": "outdent" }
    },
    {
      "beforeText": "^\\s*if\\s+.*\\s+then\\s*$",
      "action": { "indent": "indent" }
    },
    {
      "beforeText": "^\\s*while\\s+.*\\s+do\\s*$",
      "action": { "indent": "indent" }
    },
    {
      "beforeText": "^\\s*for\\s+.*\\s+(to|downto)\\s+.*\\s+do\\s*$",
      "action": { "indent": "indent" }
    },
    {
      "beforeText": "^\\s*case\\s+.*\\s+of\\s*$",
      "action": { "indent": "indent" }
    }
  ]
}