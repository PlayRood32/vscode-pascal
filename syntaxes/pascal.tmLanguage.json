          "name": "support.function.builtin.pascal",
          "match": "(?i)\\b(Length|SetLength|Copy|Pos|Delete|Insert|Str|Val|Format|FillChar|Move|SizeOf|TypeOf|TypeInfo|GetTypeKind|High|Low|Pred|Succ|Inc|Dec|Odd|Swap|Assigned)\\b"
        }
