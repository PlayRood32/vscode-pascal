{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Pascal",
  "scopeName": "source.pascal",
  "fileTypes": [
    "pas",
    "p",
    "pp",
    "dfm",
    "fmx",
    "dpr",
    "dpk",
    "lfm",
    "lpr",
    "inc",
    "lrs"
  ],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#directives" },
    { "include": "#attributes" },
    { "include": "#io-functions" },
    { "include": "#builtin-functions" },
    { "include": "#standard-functions" },
    { "include": "#math-functions" },
    { "include": "#string-functions" },
    { "include": "#conversion-functions" },
    { "include": "#datetime-functions" },
    { "include": "#file-functions" },
    { "include": "#memory-functions" },
    { "include": "#system-functions" },
    { "include": "#variant-functions" },
    { "include": "#thread-functions" },
    { "include": "#rtl-functions" },
    { "include": "#vcl-classes" },
    { "include": "#fmx-classes" },
    { "include": "#lcl-classes" },
    { "include": "#standard-classes" },
    { "include": "#collection-classes" },
    { "include": "#stream-classes" },
    { "include": "#exception-classes" },
    { "include": "#database-classes" },
    { "include": "#xml-classes" },
    { "include": "#json-classes" },
    { "include": "#network-classes" },
    { "include": "#graphics-classes" },
    { "include": "#keywords" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#types" },
    { "include": "#pointer-types" },
    { "include": "#system-types" },
    { "include": "#constants" },
    { "include": "#generics" },
    { "include": "#function-declarations" },
    { "include": "#class-declarations" },
    { "include": "#interface-declarations" },
    { "include": "#record-declarations" },
    { "include": "#variables" },
    { "include": "#units" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.pascal",
          "begin": "\\{",
          "end": "\\}",
          "patterns": [
            {
              "name": "comment.block.todo.pascal",
              "match": "\\b(TODO|FIXME|NOTE|HACK|BUG|XXX|REFACTOR|OPTIMIZE|REVIEW|IDEA|CHANGED|DEPRECATED)\\b"
            }
          ]
        },
        {
          "name": "comment.block.pascal",
          "begin": "\\(\\*",
          "end": "\\*\\)",
          "patterns": [
            {
              "name": "comment.block.todo.pascal",
              "match": "\\b(TODO|FIXME|NOTE|HACK|BUG|XXX|REFACTOR|OPTIMIZE|REVIEW|IDEA|CHANGED|DEPRECATED)\\b"
            }
          ]
        },
        {
          "name": "comment.line.double-slash.pascal",
          "match": "//.*$",
          "captures": {
            "0": {
              "patterns": [
                {
                  "name": "comment.line.todo.pascal",
                  "match": "\\b(TODO|FIXME|NOTE|HACK|BUG|XXX|REFACTOR|OPTIMIZE|REVIEW|IDEA|CHANGED|DEPRECATED):?\\s*"
                }
              ]
            }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.single.pascal",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.pascal",
              "match": "''|#\\d+|#\\$[0-9A-Fa-f]+"
            }
          ]
        },
        {
          "name": "string.quoted.double.pascal",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.pascal",
              "match": "\"\"|#\\d+|#\\$[0-9A-Fa-f]+"
            }
          ]
        },
        {
          "name": "string.other.char.pascal",
          "match": "#\\d+|#\\$[0-9A-Fa-f]+"
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "meta.preprocessor.pascal",
          "begin": "\\{\\$",
          "end": "\\}",
          "patterns": [
            {
              "name": "keyword.control.directive.conditional.pascal",
              "match": "\\b(IFDEF|IFNDEF|IFOPT|ELSE|ELSEIF|ENDIF|DEFINE|UNDEF|IF|IFEND)\\b"
            },
            {
              "name": "keyword.control.directive.include.pascal",
              "match": "\\b(INCLUDE|I|RESOURCE|R)\\b"
            },
            {
              "name": "keyword.control.directive.mode.pascal",
              "match": "\\b(MODE|MODESWITCH|MACRO|CALLING|OBJECTCHECKS|POINTERMATH)\\b"
            },
            {
              "name": "keyword.control.directive.optimization.pascal",
              "match": "\\b(OPTIMIZATION|O|INLINE|SMARTLINK|CODEPAGE|COPERATORS)\\b"
            },
            {
              "name": "keyword.control.directive.debug.pascal",
              "match": "\\b(ASSERTIONS|C|DEBUGINFO|D|LOCALSYMBOLS|L|REFERENCEINFO|Y)\\b"
            },
            {
              "name": "keyword.control.directive.checking.pascal",
              "match": "\\b(RANGECHECKS|R|IOCHECKS|I|OVERFLOWCHECKS|Q|TYPEDADDRESS|T|BOOLEVAL|B|SAFEDIVIDE|VARSTRINGCHECKS|V|WRITEABLECONST|J|STACKFRAMES|W)\\b"
            },
            {
              "name": "keyword.control.directive.syntax.pascal",
              "match": "\\b(LONGSTRINGS|H|OPENSTRINGS|P|EXTENDEDSYNTAX|X|SCOPEDENUMS|TYPEINFO|M|RTTI)\\b"
            },
            {
              "name": "keyword.control.directive.alignment.pascal",
              "match": "\\b(ALIGN|A|PACKENUM|Z|PACKRECORDS|PACKSET)\\b"
            },
            {
              "name": "keyword.control.directive.warning.pascal",
              "match": "\\b(HINTS|WARNINGS|WARN|MESSAGE|HINT|ERROR|FATAL|INFO|NOTE)\\b"
            },
            {
              "name": "keyword.control.directive.linking.pascal",
              "match": "\\b(LINK|LINKLIB|L|STATIC|DYNAMIC|WEAKLINKRTTI|SETPEFLAGS|SETPEOPTFLAGS)\\b"
            },
            {
              "name": "keyword.control.directive.other.pascal",
              "match": "\\b(APPTYPE|DESCRIPTION|EXTENSION|LIBPREFIX|LIBSUFFIX|LIBVERSION|MAINPROGRAMHANDLE|MINSTACKSIZE|MAXSTACKSIZE|IMAGEBASE|REGION|ENDREGION|LEGACYIFEND|GOTO|IMPLICITEXCEPTIONS|OLDTYPELAYOUT|INTERFACES)\\b"
            }
          ]
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "storage.modifier.attribute.pascal",
          "begin": "\\[",
          "end": "\\]",
          "patterns": [
            {
              "include": "#strings"
            },
            {
              "include": "#numbers"
            }
          ]
        }
      ]
    },
    "io-functions": {
      "patterns": [
        {
          "name": "support.function.io.pascal",
          "match": "(?i)\\b(Write|WriteLn|Read|ReadLn|Assign|Reset|Rewrite|Close|Append|Flush|Eof|Eoln|SeekEof|SeekEoln|FilePos|FileSize|Seek|Erase|Rename|Truncate|BlockRead|BlockWrite|SetTextBuf|ChDir|GetDir|MkDir|RmDir)\\b"
        }
