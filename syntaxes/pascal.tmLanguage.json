{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Pascal",
  "scopeName": "source.pascal",
  "fileTypes": ["pas", "p", "pp", "dfm", "fmx", "dpr", "dpk", "lfm", "lpr"],
  "patterns": [
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#comments" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#types" },
    { "include": "#variables" },
    { "include": "#constants" },
    { "include": "#directives" },
    { "include": "#attributes" },
    { "include": "#generics" }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.pascal",
          "match": "\\b(?i:(absolute|abstract|and_then|array|as|asm|attribute|begin|case|class|const|default|div|else|end|except|export|external|file|finalization|finally|for|forward|generic|goto|if|implements|in|inherited|initialization|interface|is|label|library|mod|not|object|of|on|operator|or_else|out|override|packed|private|program|protected|public|published|qualified|read|record|resourcestring|set|shl|shr|then|threadvar|to|try|type|unit|uses|var|virtual|while|with|write|xor|repeat|until|raise|do|downto|break|continue|exit))\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.single.pascal",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "match": "[^']+", "name": "string.content" },
            { "match": "''", "name": "constant.character.escape.pascal" }
          ]
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.pascal",
          "match": "//.*$"
        },
        {
          "name": "comment.block.braces.pascal",
          "begin": "\\{",
          "end": "\\}"
        },
        {
          "name": "comment.block.parentheses.pascal",
          "begin": "\\(\\*",
          "end": "\\*\\)"
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.hex.pascal", "match": "\\$[0-9A-Fa-f]+" },
        { "name": "constant.numeric.binary.pascal", "match": "\\b%[01]+\\b" },
        { "name": "constant.numeric.float.pascal", "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?\\b" },
        { "name": "constant.numeric.integer.pascal", "match": "\\b\\d+\\b" }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pascal",
          "match": "(\\+|\\-|\\*|\\/|:=|=|<>|<|>|<=|>=|\\.\\.|\\.)"
        },
        {
          "name": "keyword.operator.pointer.pascal",
          "match": "(@|\\^)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.pascal",
          "match": "\\b(?i:(write|writeln|Write|WriteLn|read|readln|Read|ReadLn|str|val|inc|dec|new|dispose|ord|chr|length|setlength|copy|pos|delete|insert|upcase|lowcase|trim|format|inttostr|strtoint|floattostr|strtofloat|datetostr|strtodate|now|random|randomize|sqrt|sin|cos|tan|abs|round|trunc|assert|halt|exit|break|continue))\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.pascal",
          "match": "\\b(?i:(ansichar|ansistring|boolean|byte|cardinal|char|comp|currency|double|integer|int64|longint|nativeint|real|shortint|single|smallint|string|uint64|variant|widechar|word|array|set|record|class|object|interface|pointer))\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.pascal",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.pascal",
          "match": "\\b(?i:(nil|true|false|MaxInt|MaxLongint))\\b"
        }
      ]
    },
    "directives": {
      "patterns": [
        { "name": "meta.preprocessor.pascal", "match": "\\{\\$[^}]+\\}" },
        {
          "name": "meta.preprocessor.ifdef.pascal",
          "begin": "\\{\\$IFDEF\\b",
          "end": "\\{\\$ENDIF\\b",
          "patterns": [
            { "name": "meta.preprocessor.else.pascal", "match": "\\{\\$ELSE\\b" },
            { "name": "meta.preprocessor.elseif.pascal", "match": "\\{\\$ELSEIF\\b" }
          ]
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "storage.modifier.pascal",
          "match": "\\[.*?\\]"
        }
      ]
    },
    "generics": {
      "patterns": [
        {
          "name": "storage.type.generic.pascal",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*<[^>]+>\\b"
        },
        {
          "name": "keyword.other.specialize.pascal",
          "match": "\\bspecialize\\b"
        }
      ]
    }
  }
}