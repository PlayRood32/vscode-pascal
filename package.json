{
  "name": "pascal-complete-pro",
  "displayName": "Pascal Complete",
  "description": "Professional Pascal IDE: AI-like intelligence, real-time diagnostics, smart completion, advanced refactoring, LSP integration",
  "version": "3.0.0",
  "publisher": "PlayRood32",
  "author": {
    "name": "PlayRood32"
  },
  "license": "MIT",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#0066CC",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Linters",
    "Formatters",
    "Debuggers"
  ],
  "keywords": [
    "pascal",
    "delphi",
    "free pascal",
    "lazarus",
    "fpc",
    "object pascal",
    "turbo pascal",
    "syntax highlighting",
    "intellisense",
    "diagnostics",
    "code completion",
    "refactoring",
    "code actions",
    "smart editing"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/PlayRood32/vscode-pascal"
  },
  "bugs": {
    "url": "https://github.com/PlayRood32/vscode-pascal/issues"
  },
  "homepage": "https://github.com/PlayRood32/vscode-pascal#readme",
  "activationEvents": [
    "onLanguage:pascal"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "pascal",
        "aliases": [
          "Pascal",
          "pascal",
          "Delphi",
          "Object Pascal",
          "Free Pascal"
        ],
        "extensions": [
          ".pas",
          ".pp",
          ".p",
          ".dpr",
          ".lpr",
          ".dpk",
          ".lpk",
          ".inc",
          ".dproj",
          ".lpi",
          ".dfm",
          ".lfm",
          ".fmx"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./images/icon.svg",
          "dark": "./images/icon.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "pascal",
        "scopeName": "source.pascal",
        "path": "./syntaxes/pascal.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "pascal",
        "path": "./snippets/snippets.json"
      }
    ],
    "commands": [
      {
        "command": "pascal.compile",
        "title": "Pascal: Compile Current File",
        "icon": "$(play)"
      },
      {
        "command": "pascal.run",
        "title": "Pascal: Run Compiled File",
        "icon": "$(run)"
      },
      {
        "command": "pascal.compileAndRun",
        "title": "Pascal: Compile and Run",
        "icon": "$(debug-start)"
      },
      {
        "command": "pascal.cleanBuild",
        "title": "Pascal: Clean Build Files",
        "icon": "$(trash)"
      },
      {
        "command": "pascal.formatDocument",
        "title": "Pascal: Format Document",
        "icon": "$(edit)"
      },
      {
        "command": "pascal.showStatus",
        "title": "Pascal: Show Extension Status",
        "icon": "$(info)"
      },
      {
        "command": "pascal.analyzeFile",
        "title": "Pascal: Analyze Current File",
        "icon": "$(search)"
      },
      {
        "command": "pascal.showSymbols",
        "title": "Pascal: Show All Symbols",
        "icon": "$(symbol-class)"
      },
      {
        "command": "pascal.refreshSymbols",
        "title": "Pascal: Refresh Symbol Cache",
        "icon": "$(refresh)"
      },
      {
        "command": "pascal.openDocs",
        "title": "Pascal: Open Documentation",
        "icon": "$(book)"
      },
      {
        "command": "pascal.checkSyntax",
        "title": "Pascal: Check Syntax",
        "icon": "$(check)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceLangId == pascal",
          "command": "pascal.compileAndRun",
          "group": "navigation@1"
        },
        {
          "when": "resourceLangId == pascal",
          "command": "pascal.formatDocument",
          "group": "navigation@2"
        }
      ],
      "editor/context": [
        {
          "when": "resourceLangId == pascal",
          "command": "pascal.compile",
          "group": "pascal@1"
        },
        {
          "when": "resourceLangId == pascal",
          "command": "pascal.run",
          "group": "pascal@2"
        },
        {
          "when": "resourceLangId == pascal",
          "command": "pascal.analyzeFile",
          "group": "pascal@3"
        },
        {
          "when": "resourceLangId == pascal",
          "command": "pascal.cleanBuild",
          "group": "pascal@4"
        }
      ],
      "commandPalette": [
        {
          "command": "pascal.compile",
          "when": "resourceLangId == pascal"
        },
        {
          "command": "pascal.run",
          "when": "resourceLangId == pascal"
        },
        {
          "command": "pascal.compileAndRun",
          "when": "resourceLangId == pascal"
        },
        {
          "command": "pascal.formatDocument",
          "when": "resourceLangId == pascal"
        },
        {
          "command": "pascal.analyzeFile",
          "when": "resourceLangId == pascal"
        },
        {
          "command": "pascal.checkSyntax",
          "when": "resourceLangId == pascal"
        }
      ]
    },
    "keybindings": [
      {
        "command": "pascal.compile",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b",
        "when": "editorTextFocus && resourceLangId == pascal"
      },
      {
        "command": "pascal.compileAndRun",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "editorTextFocus && resourceLangId == pascal"
      },
      {
        "command": "pascal.run",
        "key": "ctrl+r",
        "mac": "cmd+r",
        "when": "editorTextFocus && resourceLangId == pascal"
      },
      {
        "command": "pascal.cleanBuild",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c",
        "when": "editorTextFocus && resourceLangId == pascal"
      },
      {
        "command": "pascal.formatDocument",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f",
        "when": "editorTextFocus && resourceLangId == pascal"
      },
      {
        "command": "pascal.analyzeFile",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorTextFocus && resourceLangId == pascal"
      }
    ],
    "configuration": {
      "title": "Pascal Complete",
      "properties": {
        "pascal.compilerPath": {
          "type": "string",
          "default": "fpc",
          "description": "Path to Free Pascal Compiler (fpc or full path)",
          "scope": "resource"
        },
        "pascal.compilerMode": {
          "type": "string",
          "default": "FPC",
          "enum": ["FPC", "Delphi", "TP", "MacPas", "ISO"],
          "enumDescriptions": [
            "Free Pascal mode (default)",
            "Delphi compatibility mode",
            "Turbo Pascal mode",
            "Mac Pascal mode",
            "ISO Pascal mode"
          ],
          "description": "Compiler compatibility mode",
          "scope": "resource"
        },
        "pascal.compilerOptions": {
          "type": "array",
          "default": [],
          "description": "Additional compiler flags (e.g., [\"-O2\", \"-g\"])",
          "scope": "resource"
        },
        "pascal.syntaxCheckOnChange": {
          "type": "boolean",
          "default": true,
          "description": "Enable real-time syntax checking while typing (debounced)",
          "scope": "resource"
        },
        "pascal.syntaxCheckOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Check syntax when saving file",
          "scope": "resource"
        },
        "pascal.showWarnings": {
          "type": "boolean",
          "default": true,
          "description": "Show compiler warnings in Problems panel",
          "scope": "resource"
        },
        "pascal.showHints": {
          "type": "boolean",
          "default": false,
          "description": "Show compiler hints and notes",
          "scope": "resource"
        },
        "pascal.formatOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically format code on save",
          "scope": "resource"
        },
        "pascal.indentSize": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 8,
          "description": "Number of spaces for indentation",
          "scope": "resource"
        },
        "pascal.insertSpaces": {
          "type": "boolean",
          "default": true,
          "description": "Use spaces instead of tabs for indentation",
          "scope": "resource"
        },
        "pascal.autoSemicolon": {
          "type": "boolean",
          "default": true,
          "description": "Automatically insert semicolons (context-aware)",
          "scope": "resource"
        },
        "pascal.autoCloseBrackets": {
          "type": "boolean",
          "default": true,
          "description": "Automatically close brackets and blocks",
          "scope": "resource"
        },
        "pascal.enableCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show CodeLens for procedures and functions",
          "scope": "resource"
        },
        "pascal.enableHoverDocs": {
          "type": "boolean",
          "default": true,
          "description": "Show documentation on hover",
          "scope": "resource"
        },
        "pascal.enableSignatureHelp": {
          "type": "boolean",
          "default": true,
          "description": "Show parameter hints for functions",
          "scope": "resource"
        },
        "pascal.lspEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Language Server Protocol (requires pasls)",
          "scope": "resource"
        },
        "pascal.debugMode": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose debug logging",
          "scope": "resource"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.22.0"
  }
}